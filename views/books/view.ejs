<%- include('../port/header', {title: title}) %>
<%- include('../port/menu') %>

<h1><%= title %></h1>
<h3>Просмотров: <%= count %></h3>

<div class="row">
    <div class="col-sm-8">
        <div class="card">
            <div class="card-body">

                <h5 class="card-title"><%= book.title %></h5>
                <p class="card-text"><%= book.description %></p>

                <div class="text-right">
                    <a class="btn btn-sm btn-primary" href="/books/update/<%= book.id %>">
                        <i class="fa fa-pencil" aria-hidden="true"></i>
                    </a>
                    <form action="/books/delete/<%= book.id %>" method="POST" class="d-inline">
                        <button class="btn btn-sm btn-danger">
                            <i class="fa fa-trash" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-4">
        <div id="list" class="list-group">

        </div>
    </div>
</div>

<div class="row">
    <div class="col-4">
        <div class="form-group">
            <label for="username">username</label>
            <input
                    placeholder="username"
                    type="text"
                    id="username"
                    class="form-control"
            >
        </div>
        <div class="form-group">
            <label for="text">message</label>
            <textarea
                    placeholder="message"
                    class="form-control"
                    id="text"
            ></textarea>
        </div>
        <button type="submit" id="send-to-book" class="btn btn-primary">Отправить</button>
    </div>
</div>


<script>
    const bookId = location.pathname.split('/').pop();
    console.log(bookId);
    const socket = io.connect('/', {query: `book=${bookId}`});

    const boxList       = document.querySelector('#list');
    const inputUsername = document.querySelector('#username');
    const inputText     = document.querySelector('#text');
    const sendRoom      = document.querySelector('#send-to-book');

    const getTmp = (msg) => {
        return `
            <div class="list-group-item list-group-item-action">
                <div class="d-flex w-100 justify-content-between">
                    <small>${msg.username}</small>
                </div>
                <p class="mb-1">${msg.text}</p>
            </div>
        `;
    };

    socket.on('msg-to-book', (msg) => {
        const div = getTmp(msg)
        boxList.insertAdjacentHTML('beforeend', div)
    });

    sendRoom.addEventListener('click', () => {
        socket.emit('msg-to-book', {
            username: inputUsername.value,
            text: inputText.value,
        })
    })
</script>

<%- include('../port/footer') %>