<%- include('../port/header', {title: title}) %>
<%- include('../port/menu') %>

<h1><%= title %></h1>
<h3>Просмотров: <%= count %></h3>

<div class="row">
    <div class="col-sm-8">
        <div class="card">
            <div class="card-body">

                <h5 class="card-title"><%= book.title %></h5>
                <p class="card-text"><%= book.description %></p>

                <div class="text-right">
                    <a class="btn btn-sm btn-primary" href="/books/update/<%= book.id %>">
                        <i class="fa fa-pencil" aria-hidden="true"></i>
                    </a>
                    <form action="/books/delete/<%= book.id %>" method="POST" class="d-inline">
                        <button class="btn btn-sm btn-danger">
                            <i class="fa fa-trash" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-4">
        <h3>Комментарии</h3>
        <div id="list" class="list-group">

        </div>
    </div>
</div>

<div class="row">
    <div class="col-4">
        <h3>Оставить комментарий</h3>
        <div class="form-group">
            <label for="username">username</label>
            <input
                    placeholder="username"
                    type="text"
                    id="username"
                    class="form-control"
            >
        </div>
        <div class="form-group">
            <label for="text">message</label>
            <textarea
                    placeholder="message"
                    class="form-control"
                    id="text"
            ></textarea>
        </div>
        <button type="submit" id="send-to-book" class="btn btn-primary">Отправить</button>
    </div>
</div>


<script>
    const bookId = location.pathname.split('/').pop();
    console.log(bookId);

    const socket = io({
        query: { bookId }
    });

    const boxList       = document.querySelector('#list');
    const inputUsername = document.querySelector('#username');
    const inputText     = document.querySelector('#text');
    const sendRoom      = document.querySelector('#send-to-book');

    const getTmp = (msg) => {
        const time = msg.timestamp
            ? new Date(msg.timestamp).toLocaleTimeString()
            : new Date().toLocaleTimeString();

        return `
            <div class="list-group-item list-group-item-action">
              <div class="d-flex w-100 justify-content-between">
                <small class="text-primary">${escapeHtml(msg.username || 'Аноним')}</small>
                <small class="text-muted">${time}</small>
              </div>
              <p class="mb-1 mt-2">${escapeHtml(msg.text)}</p>
            </div>
  `;
    };

    const escapeHtml = (text) => {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    const appendComment = (msg) => {
        const div = getTmp(msg);
        boxList.insertAdjacentHTML('beforeend', div);
    }

    socket.on('connect', () => {
        console.log('Connected to WebSocket server');
    });

    socket.on('connect_error', (err) => {
        console.error('Connection error:', err);
    });

    socket.on('load-comments', (comments) => {
        comments.forEach(appendComment);
    });

    socket.on('msg-to-book', (msg) => {
        const div = getTmp(msg)
        boxList.insertAdjacentHTML('beforeend', div)
    });

    sendRoom.addEventListener('click', () => {
        socket.emit('msg-to-book', {
            username: inputUsername.value || 'Аноним',
            text: inputText.value,
        })

        inputUsername.value = '';
        inputText.value = '';
    })
</script>

<%- include('../port/footer') %>